# ─── Convex ────────────────────────────────────────────────────────────────
# Get this from: https://dashboard.convex.dev → your project → Settings
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ─── Clerk (Public) ─────────────────────────────────────────────────────────
# Get these from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Auth redirect configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Clerk (Server-only) ─────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...

# Webhook secret from Clerk Dashboard → Webhooks → your endpoint
# Endpoint URL: https://your-domain.com/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk JWT issuer domain (for Convex auth)
# Format: https://your-clerk-app.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to use static fixture data (no Convex connection needed)
NEXT_PUBLIC_DEMO_MODE=false
